{
  "name": "open-fps",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode editor",
    "dev:editor": "vite --mode editor",
    "dev:game": "vite --mode game",
    "build": "tsc && vite build --mode editor",
    "build:editor": "tsc && vite build --mode editor",
    "build:game": "tsc && vite build --mode game",
    "lint": "oxlint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev:editor": "node scripts/run-tauri-target.mjs dev editor",
    "tauri:dev:game": "node scripts/run-tauri-target.mjs dev game",
    "tauri:build:editor": "node scripts/run-tauri-target.mjs build editor",
    "tauri:build:game": "node scripts/run-tauri-target.mjs build game",
    "tauri:debug:editor": "node scripts/run-tauri-target.mjs build editor --debug --no-bundle",
    "tauri:debug:game": "node scripts/run-tauri-target.mjs build game --debug --no-bundle",
    "tauri:release:editor": "node scripts/run-tauri-target.mjs build editor --ci --no-sign",
    "tauri:release:game": "node scripts/run-tauri-target.mjs build game --ci --no-sign",
    "release:sync-version": "node scripts/sync-version-from-tag.mjs",
    "generate:terrain": "node scripts/generate-terrain-map.mjs",
    "generate:splatmaps": "node scripts/generate-default-splatmaps.mjs",
    "generate:test-pro-terrain": "node scripts/generate-terrain-map.mjs test_pro",
    "generate:test-pro-maps": "node scripts/generate-terrain-map.mjs test_pro --all",
    "generate:test-pro-splatmaps": "node scripts/generate-default-splatmaps.mjs test_pro",
    "ci:frontend:editor": "pnpm build:editor",
    "ci:frontend:game": "pnpm build:game",
    "ci:tauri:editor": "node scripts/run-tauri-target.mjs build editor --ci --no-bundle",
    "ci:tauri:game": "node scripts/run-tauri-target.mjs build game --ci --no-bundle"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "three-mesh-bvh": "^0.9.9"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.2",
    "@tauri-apps/cli": "^2.9.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxlint": "^1.57.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.3"
  }
}
