{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "open-fps-game",
  "mainBinaryName": "open-fps-game",
  "version": "0.1.0",
  "identifier": "open-fps.game",
  "build": {
    "beforeDevCommand": "pnpm dev:game",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build:game",
    "frontendDist": "../dist-game"
  },
  "app": {
    "windows": [
      {
        "title": "open-fps game",
        "width": 1200,
        "height": 800,
        "closable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/game/32x32.png",
      "icons/game/128x128.png",
      "icons/game/128x128@2x.png",
      "icons/game/icon.icns",
      "icons/game/icon.ico"
    ]
  }
}