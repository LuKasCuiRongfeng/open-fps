{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "open-fps-editor",
  "mainBinaryName": "open-fps-editor",
  "version": "../package.json",
  "identifier": "open-fps.editor",
  "build": {
    "beforeDevCommand": "pnpm dev:editor",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build:editor",
    "frontendDist": "../dist-editor"
  },
  "app": {
    "windows": [
      {
        "title": "open-fps editor",
        "width": 1200,
        "height": 800,
        "closable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/editor/32x32.png",
      "icons/editor/128x128.png",
      "icons/editor/128x128@2x.png",
      "icons/editor/icon.icns",
      "icons/editor/icon.ico"
    ]
  }
}